<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="demo"/>

    <property name="CONSOLE_LOG_CHARSET" value="UTF-8"/>
    <property name="FILE_LOG_CHARSET" value="UTF-8"/>
    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %X{traceId} %cyan([%thread]) %magenta(%logger{36} - %msg%n)"/>
    <property name="FILE_LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) %X{traceId} %cyan([%thread]) %magenta(%logger{36} - %msg%n)"/>

    <property name="LOG_FILE" value="logs/${APP_NAME}.log"/>
    <property name="LOGBACK_ROLLINGPOLICY_FILE_NAME_PATTERN" value="logs/${APP_NAME}%d{yyyy-MM-dd}.%i.log"/>
    <property name="LOGBACK_ROLLINGPOLICY_MAX_HISTORY" value="30"/>
    <property name="LOGBACK_ROLLINGPOLICY_TOTAL_SIZE_CAP" value="1GB"/>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>
    <include resource="org/springframework/boot/logging/logback/file-appender.xml"/>

    <springProfile name="dev">
        <logger name="com" level="${LOG_LEVEL_COM:-DEBUG}"/>
        <logger name="cn.com" level="${LOG_LEVEL_CN_COM:-DEBUG}"/>
        <logger name="org.springframework" level="${LOG_LEVEL_SPRING:-WARN}"/>
        <logger name="org.springframework.web" level="${LOG_LEVEL_SPRING_WEB:-WARN}"/>
        <logger name="com.baomidou.dynamic.datasource" level="${LOG_LEVEL_DYNAMIC_DATASOURCE:-INFO}"/>
        <logger name="com.alibaba.druid" level="${LOG_LEVEL_DRUID:-INFO}"/>
    </springProfile>

    <root level="${LOG_LEVEL_ROOT:-INFO}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
