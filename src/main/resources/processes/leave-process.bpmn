<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
        xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
        targetNamespace="http://example.com/leave">

    <bpmn:process id="leaveProcess" name="请假流程" isExecutable="true"
                  camunda:initiator="applicant">

        <!-- 发起请假：填写天数、原因 -->
        <bpmn:startEvent id="StartEvent_Leave" name="发起请假">
            <bpmn:extensionElements>
                <camunda:formData>
                    <camunda:formField id="days" label="请假天数" type="long">
                        <camunda:validation>
                            <camunda:constraint name="min" config="1"/>
                        </camunda:validation>
                    </camunda:formField>
                    <camunda:formField id="reason" label="请假原因" type="string"/>
                </camunda:formData>
            </bpmn:extensionElements>
        </bpmn:startEvent>

        <!-- 组长审批 -->
        <bpmn:userTask id="UserTask_LeaderApprove" name="组长审批"
                       camunda:candidateGroups="leaders">
            <bpmn:extensionElements>
                <camunda:formData>
                    <camunda:formField id="leaderApproved" label="是否同意" type="boolean"/>
                    <camunda:formField id="leaderComment" label="审批意见" type="string"/>
                </camunda:formData>
            </bpmn:extensionElements>
        </bpmn:userTask>

        <!-- 组长审批结果 -->
        <bpmn:exclusiveGateway id="Gateway_LeaderDecision" name="组长审批结果"
                               default="Flow_Leader_DefaultReject"/>

        <!-- 经理审批 -->
        <bpmn:userTask id="UserTask_ManagerApprove" name="经理审批"
                       camunda:candidateGroups="managers">
            <bpmn:extensionElements>
                <camunda:formData>
                    <camunda:formField id="managerApproved" label="是否同意" type="boolean"/>
                    <camunda:formField id="managerComment" label="审批意见" type="string"/>
                </camunda:formData>
            </bpmn:extensionElements>
        </bpmn:userTask>

        <!-- 经理审批结果 -->
        <bpmn:exclusiveGateway id="Gateway_ManagerDecision" name="经理审批结果"
                               default="Flow_Manager_DefaultReject"/>

        <!-- 结束 -->
        <bpmn:endEvent id="EndEvent_Approved" name="审批通过"/>
        <bpmn:endEvent id="EndEvent_Rejected" name="审批拒绝"/>

        <!-- 流转 -->
        <bpmn:sequenceFlow id="Flow_Start_To_Leader" sourceRef="StartEvent_Leave" targetRef="UserTask_LeaderApprove"/>
        <bpmn:sequenceFlow id="Flow_Leader_To_Gw" sourceRef="UserTask_LeaderApprove" targetRef="Gateway_LeaderDecision"/>

        <!-- leaderApproved == true && days > 3 -> manager -->
        <bpmn:sequenceFlow id="Flow_Leader_To_Manager" sourceRef="Gateway_LeaderDecision" targetRef="UserTask_ManagerApprove">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
                ${leaderApproved == true &amp;&amp; days > 3}
            </bpmn:conditionExpression>
        </bpmn:sequenceFlow>

        <!-- leaderApproved == true && days <= 3 -> approved -->
        <bpmn:sequenceFlow id="Flow_Leader_To_Approved" sourceRef="Gateway_LeaderDecision" targetRef="EndEvent_Approved">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
                ${leaderApproved == true &amp;&amp; days &lt;= 3}
            </bpmn:conditionExpression>
        </bpmn:sequenceFlow>

        <!-- default -> rejected（覆盖 leaderApproved=false / null / days缺失等异常输入） -->
        <bpmn:sequenceFlow id="Flow_Leader_DefaultReject" sourceRef="Gateway_LeaderDecision" targetRef="EndEvent_Rejected"/>

        <bpmn:sequenceFlow id="Flow_Manager_To_Gw" sourceRef="UserTask_ManagerApprove" targetRef="Gateway_ManagerDecision"/>

        <!-- managerApproved == true -> approved -->
        <bpmn:sequenceFlow id="Flow_Manager_To_Approved" sourceRef="Gateway_ManagerDecision" targetRef="EndEvent_Approved">
            <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
                ${managerApproved == true}
            </bpmn:conditionExpression>
        </bpmn:sequenceFlow>

        <!-- default -> rejected -->
        <bpmn:sequenceFlow id="Flow_Manager_DefaultReject" sourceRef="Gateway_ManagerDecision" targetRef="EndEvent_Rejected"/>

    </bpmn:process>
</bpmn:definitions>