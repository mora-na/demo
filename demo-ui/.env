# API origin (domain only). When set, frontend uses {origin}/prod-api.
VITE_API_ORIGIN=https://demo-api.mora.dpdns.org
# API base URL fallback (full path). Used if VITE_API_ORIGIN is empty.
VITE_API_BASE_URL=/prod-api
# Dev server proxy target for local development.
VITE_API_PROXY_TARGET=http://localhost:8080
# Whether to include cookies/credentials in API requests.
VITE_API_WITH_CREDENTIALS=false
# Password transport algorithm.
VITE_PASSWORD_TRANSPORT_MODE=sm2
# SM2 public key used to encrypt transported passwords.
VITE_PASSWORD_TRANSPORT_SM2_PUBLIC_KEY=MFkwEwYHKoZIzj0CAQYIKoEcz1UBgi0DQgAEBDTmsaR1pRSFa3h2TMSxL6CqfY7OQziDKSF0IrOmDsc2SaGj3d1yKmWqo5pyGtPpFJBalYLYcBRChsT4xvBaQA==
